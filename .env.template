# ═══════════════════════════════════════════════════════════════════════════
# DevGuard AI — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# 
# Copy this file to .env and fill in your actual values.
# All keys are required for the application to work fully.
#
# SETUP INSTRUCTIONS:
# 1. Copy .env.template → .env
# 2. Fill in each API key following the instructions below
# 3. Run: pip install -r requirements.txt
# 4. Run: uvicorn main:app --reload
# 5. Visit: http://localhost:8000/docs for API documentation

# ═══════════════════════════════════════════════════════════════════════════
# 1. GitHub API Integration
# ═══════════════════════════════════════════════════════════════════════════
# Required for analyzing repositories and pull requests.
#
# Setup:
#   1. Go to: https://github.com/settings/tokens
#   2. Click "Generate new token (classic)"
#   3. Select scopes:
#      - "repo" for full repo access (includes private repos)
#      - OR no scope for public repos only
#   4. Generate and copy the token
#
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ═══════════════════════════════════════════════════════════════════════════
# 2. AI Code Analysis Provider
# ═══════════════════════════════════════════════════════════════════════════
# Determines which AI service analyzes code for bugs, security issues, etc.

# Provider choice: "gemini" (default) or "claude"
# 
# RECOMMENDED FOR HACKATHONS: gemini
# - Free tier: 15 requests per minute, unlimited prompts
# - Models: gemini-2.5-flash (newest and fastest)
# - No credit card required for free tier
#
AI_PROVIDER=gemini

# ═══════════════════════════════════════════════════════════════════════════
# 3. Google Gemini API Key (for AI_PROVIDER=gemini)
# ═══════════════════════════════════════════════════════════════════════════
# 
# Setup:
#   1. Go to: https://aistudio.google.com/app/apikey
#   2. Click "Create API key"
#   3. Copy the generated key
#
# Free tier limits: 15 RPM, no credit card required
#
GEMINI_API_KEY=AIzaSyDxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ═══════════════════════════════════════════════════════════════════════════
# 4. Anthropic Claude API Key (optional, for AI_PROVIDER=claude)
# ═══════════════════════════════════════════════════════════════════════════
# 
# Setup (if switching to Claude):
#   1. Go to: https://console.anthropic.com
#   2. Sign up for free account ($5 free credits)
#   3. Navigate to API Keys section
#   4. Create new API key
#   5. Copy the key (format: sk-ant-xxxxx)
#
# Note: Only needed if you set AI_PROVIDER=claude
#
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ═══════════════════════════════════════════════════════════════════════════
# 5. Notifications (Optional)
# ═══════════════════════════════════════════════════════════════════════════
# Send email alerts when critical bugs are detected.

# Enable/disable notifications: true or false
NOTIFY_ENABLED=false

# Resend API (for sending emails)
# Setup: https://resend.com (free tier: 100 emails/day)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTIFY_FROM=devguard@yourdomain.com
NOTIFY_TO=team@yourdomain.com

# ═══════════════════════════════════════════════════════════════════════════
# 6. Application Settings
# ═══════════════════════════════════════════════════════════════════════════

# FastAPI environment: development, production, or testing
ENVIRONMENT=development

# Maximum files to analyze per repository (controls API cost)
MAX_FILES_PER_REPO=30

# Request timeout in seconds
REQUEST_TIMEOUT=30
